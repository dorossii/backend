@base_url = https://localhost:8947/app
@friend_id = ""

###
GET {{base_url}}/

### ユーザー登録
POST {{base_url}}/user/register HTTP/1.1
Content-Type: application/json

{
  "userName": "xxxx",
  "birthDate": "2000-01-01",
  "mailAddress": "xxxx@example.com",
  "livingType": "alone"
}


### ユーザー情報更新
PUT {{base_url}}/user/setting HTTP/1.1
Content-Type: application/json

{
  "userName": "xxxx",
}


### 生活環境登録
POST {{base_url}}/user/lifestyle HTTP/1.1
Content-Type: application/json

{
  "isAlone": true,
  "hasWasher": true,
  "hasVacuum": false
}


### 生活環境更新
PUT {{base_url}}/user/lifestyle HTTP/1.1
Content-Type: application/json

{
  "isAlone": true,
  "hasWasher": true,
  "hasVacuum": false
